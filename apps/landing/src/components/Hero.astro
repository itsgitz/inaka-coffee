---
import type { Hero } from '../types/strapi';
import { resolveMediaUrl } from '../lib/strapi';

interface Props {
  hero: Hero;
}

const { hero } = Astro.props;

const bgImage = hero.backgroundImage
  ? resolveMediaUrl(hero.backgroundImage.url)
  : 'https://images.unsplash.com/photo-1511920170033-f8396924c348?w=1920&q=80';
---

<section
  id="hero"
  class="relative h-screen flex items-center justify-center overflow-hidden"
>
  <!-- Background image -->
  <div
    class="absolute inset-0 bg-cover bg-center bg-no-repeat"
    style={`background-image: url('${bgImage}');`}
  >
  </div>

  <!-- Dark overlay -->
  <div class="absolute inset-0 bg-black/50"></div>

  <!-- Content -->
  <div class="relative z-10 text-center px-4 max-w-3xl mx-auto">
    <h1
      class="text-4xl sm:text-5xl md:text-6xl font-bold text-white leading-tight mb-6"
      style="font-family: var(--font-serif);"
    >
      {hero.headline}
    </h1>

    {
      hero.subheadline && (
        <p class="text-lg sm:text-xl text-white/85 mb-8 leading-relaxed">
          {hero.subheadline}
        </p>
      )
    }

    <a
      href="#menu"
      class="inline-block px-8 py-3 rounded-full font-semibold text-white transition-all duration-300 hover:scale-105"
      style="background-color: #4A5D4E;"
    >
      Lihat Menu
    </a>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-white/70" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"
      ></path>
    </svg>
  </div>
</section>
